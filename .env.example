# Patent Space MCP — Environment Variables

# === Required ===

# Path to the SQLite patents database
PATENT_DB_PATH=./data/patents.db

# === Optional: BigQuery (for data ingestion only) ===

# GCP service account credentials JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# GCP project ID for BigQuery queries
# BIGQUERY_PROJECT=your-gcp-project-id

# === Optional: HTTP Server ===

# Host and port for HTTP transport mode (default: 127.0.0.1:8001)
# MCP_HOST=0.0.0.0
# MCP_PORT=8001

# === Optional: Display Names ===

# Path to companies_master.csv for firm_id → Japanese name resolution
# If not set, server looks in data/companies_master.csv
# COMPANIES_MASTER_CSV=/path/to/companies_master.csv
